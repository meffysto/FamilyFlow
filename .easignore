# ── EAS Build — fichiers exclus de l'upload ──────────────────────────────
# ⚠️ Quand ce fichier existe, EAS l'utilise À LA PLACE de .gitignore.
# Il faut donc y re-déclarer node_modules/.git (sinon ils sont uploadés).
# EAS réinstalle les deps + relance pod install côté cloud.

# Dépendances et git (réinstallés/inutiles côté EAS)
node_modules/
.git/

# Vidéos / screenshots / docs (marketing, pas runtime)
video/
screenshots/
docs/

# Planning et artifacts Claude
.planning/
.claude/
.agents/
.kiro/
notes.md

# App desktop Tauri (workspace séparé)
apps/

# Build artifacts
dist/
*.ipa
*.xcappdata
build-*.ipa

# Workspaces / outils séparés (pas le runtime de l'app)
agent-sprite-forge/
.mockups/
.gnhf/
.expo/

# iOS : on garde le projet (Podfile + xcodeproj + sources natives custom)
# mais on exclut les Pods et artefacts compilés — EAS relance pod install lui-même.
ios/Pods/
ios/build/
ios/DerivedData/

# IDE / tooling
.mcp.json
skills-lock.json
*.tsbuildinfo

# Tests et scripts (pas nécessaires au runtime)
scripts/
**/__tests__/
**/*.test.ts
**/*.test.tsx

# Patches appliquées au postinstall (déjà dans node_modules)
# patches/ — garder, postinstall en a besoin
