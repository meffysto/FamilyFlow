{
  "expo": {
    "name": "FamilyFlow",
    "slug": "family-vault",
    "version": "1.2.0",
    "scheme": "family-vault",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#F9FAFB"
    },
    "ios": {
      "splash": {
        "backgroundColor": "#F9FAFB"
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.familyvault.dev",
      "appleTeamId": "AKMNXGVVGX",
      "infoPlist": {
        "NSDocumentsFolderUsageDescription": "FamilyFlow a besoin d'accéder à vos documents pour lire et modifier votre vault Obsidian.",
        "NSFileProviderPresenceUsageDescription": "FamilyFlow utilise iCloud pour synchroniser votre vault Obsidian.",
        "NSCameraUsageDescription": "FamilyFlow utilise la caméra pour prendre la photo du jour.",
        "NSPhotoLibraryUsageDescription": "FamilyFlow accède à vos photos pour la photo du jour.",
        "NSFaceIDUsageDescription": "Family Vault utilise Face ID pour protéger l'accès à l'application.",
        "UIFileSharingEnabled": false,
        "LSSupportsOpeningDocumentsInPlace": true,
        "NSSpeechRecognitionUsageDescription": "FamilyFlow utilise la reconnaissance vocale pour transcrire les réponses du médecin.",
        "NSMicrophoneUsageDescription": "FamilyFlow utilise le micro pour transcrire les consultations médicales.",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "whatsapp",
          "sms",
          "tel"
        ]
      },
      "buildNumber": "21"
    },
    "android": {
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#F9FAFB"
      },
      "adaptiveIcon": {
        "backgroundColor": "#EAECF0",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MANAGE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ],
      "package": "com.familyvault.app",
      "versionCode": 7
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/remove-push-entitlement",
      "./plugins/with-widget",
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Family Vault utilise Face ID pour protéger l'accès à l'application."
        }
      ],
      [
        "expo-file-system",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FamilyFlow accède à vos photos pour la photo du jour.",
          "cameraPermission": "FamilyFlow utilise la caméra pour prendre la photo du jour."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "FamilyFlow utilise le micro pour transcrire les consultations médicales.",
          "speechRecognitionPermission": "FamilyFlow utilise la reconnaissance vocale pour transcrire les réponses du médecin."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "FamilyFlow accède à vos contacts pour importer les anniversaires."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "FamilyFlow accède à votre calendrier pour importer les anniversaires."
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "MaJourneeWidget",
              "label": "Ma Journée",
              "description": "Repas, tâches et RDV du jour",
              "minWidth": "280dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000
            },
            {
              "name": "JournalBebeWidget",
              "label": "Journal Bébé",
              "description": "Dernier repas et stats du jour",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      "expo-localization",
      [
        "@sentry/react-native/expo",
        {
          "organization": "no-72d",
          "project": "react-native"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "privacyUrl": "https://meffysto.github.io/FamilyFlow/privacy.html",
      "supportUrl": "https://meffysto.github.io/FamilyFlow/support.html",
      "router": {},
      "eas": {
        "projectId": "0ca7b0af-8d38-4a79-8e90-7863bff80584",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "MaJourneeWidget",
                  "bundleIdentifier": "com.familyvault.dev.MaJourneeWidget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.familyvault.dev"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    },
    "owner": "meffysto"
  }
}
