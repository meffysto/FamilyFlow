{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "local",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "credentialsSource": "remote",
      "ios": {
        "appExtensions": [
          {
            "targetName": "MaJourneeWidget",
            "bundleIdentifier": "com.familyvault.dev.MaJourneeWidget"
          }
        ]
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "julieguasproca@gmail.com",
        "ascAppId": "6760829141",
        "appleTeamId": "AKMNXGVVGX"
      }
    }
  }
}
